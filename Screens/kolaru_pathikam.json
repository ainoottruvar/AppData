  "screens": [
    {
      "id": "kolaru_pathikam",
      "type": "TEXT",
      "title": "கோளறு பதிகம்",
      "prev": "potri_thiruthaandakam",
      "next": "thiruvempaavai",
      "fab": "paadalkal",
      "payload": {
        "html": [
          "<p><b>கோளறு பதிகம்</b></p>",
          "<p>\"வேய் உறு தோளிபங்கன் விடமுண்ட கண்டன்</p>",
          "<p>மிக நல்ல வீணை தடவி</p>",
          "<p>மாசறு திங்கள் கங்கை முடிமேல் அணிந்து என்</p>",
          "<p>உளமே புகுந்த அதனால்</p>",
          "<p>ஞாயிறு திங்கள் செவ்வாய் புதன் வியாழம் வெள்ளி</p>",
          "<p>சனி பாம்பிரண்டு முடனே</p>",
          "<p>ஆசறு நல்லநல்ல அவை நல்ல நல்ல</p>",
          "<p>அடியார&zwnj; வர்க்கu மிகவே.\"</p>",
          "<p>\"என்பொடு கொம்பொடாமை இவை மார்பிலங்க</p>",
          "<p>எருதேறி யேழை யுடனே</p>",
          "<p>பொன்பொதி மத்தமாலை புனல்சூடி வந்தென்</p>",
          "<p>உளமே புகுந்த அதனால்</p>",
          "<p>ஒன்பதொ டொன்றொடேழு ப&zwnj;தினெட்டொ டாறும்</p>",
          "<p>உடனாய நாள்க ள&zwnj;வைதாம்</p>",
          "<p>அன்பொடு நல்லநல்ல அவைநல்ல நல்ல</p>",
          "<p>அடியார&zwnj;வர்க்கு மிகவே. \"</p>",
          "<p>\"உருவளர் பவளமேனி ஒளிநீ ற&zwnj;ணிந்து</p>",
          "<p>உமையோடும் வெள்ளை விடைமேல்</p>",
          "<p>முருக&zwnj;லர் கொன்றைதிங்கள் முடிமேல&zwnj;ணிந்தென்</p>",
          "<p>உளமே புகுந்த அதனால்</p>",
          "<p>திருமகள் கலைய&zwnj;தூர்தி செயமாது பூமி</p>",
          "<p>திசை தெய்வமான பலவும்</p>",
          "<p>அருநெதி நல்லநல்ல அவை நல்லநல்ல</p>",
          "<p>அடியார&zwnj;வர்க்கு மிகவே. \"</p>",
          "<p>\"மதிநுதன் மங்கையோடு வடவா லிருந்து</p>",
          "<p>மறையோது மெங்கள் பரமன்</p>",
          "<p>நதியொடு கொன்றைமாலை முடிமேல் அணிந்தென்</p>",
          "<p>உளமே புகுந்த அதனால்</p>",
          "<p>கொதியுறு காலன் அங்கி நமனோடு தூதர்</p>",
          "<p>கொடுநோய்களான பலவும்</p>",
          "<p>அதிகுணம் நல்லநல்ல அவை நல்லநல்ல</p>",
          "<p>அடியார&zwnj;வர்க்கு மிகவே.\"</p>",
          "<p>\"நஞ்ச&zwnj;ணி கண்டனெந்தை மடவாள் தனோடும்</p>",
          "<p>விடையேறு நங்கள் பரமன்</p>",
          "<p>துஞ்சிருள் வன்னி கொன்றை முடிமேல் அணிந்தென்</p>",
          "<p>உளமே புகுந்த அதனால்</p>",
          "<p>வெஞ்சின அவுணரோடும் உருமிடியும் மின்னும்</p>",
          "<p>மிகையான பூதம&zwnj;வையும்</p>",
          "<p>அஞ்சிடும் நல்லநல்ல அவை நல்லநல்ல</p>",
          "<p>அடியார&zwnj;வர்க்கு மிகவே.\"</p>",
          "<p>\"வாள்வரி அதளதாடை வரி கோவணத்தர்</p>",
          "<p>மடவாள் தனோடும் உடனாய்</p>",
          "<p>நாள்மலர் வன்னி கொன்றை நதிசூடி வந்தென்</p>",
          "<p>உளமே புகுந்த அதனால்</p>",
          "<p>கோள&zwnj;ரி உழுவையோடு கொலையானை கேழல்</p>",
          "<p>கொடு நாகமோடு கரடி</p>",
          "<p>ஆள&zwnj;ரி நல்லநல்ல அவை நல்லநல்ல</p>",
          "<p>அடியார&zwnj;வர்க்கு மிகவே.\"</p>",
          "<p>\"செப்பிள முலைநன்மங்கை ஒருபாகமாக</p>",
          "<p>விடையேறு செல்வ னடைவார்</p>",
          "<p>ஒப்பிள மதியும் அப்பும் முடிமேல் அணிந்தென்</p>",
          "<p>உளமே புகுந்த அதனால்</p>",
          "<p>வெப்பொடு குளிரும் வாத மிகையான&zwnj பித்தும்</p>",
          "<p>வினையான வந்து நலியா</p>",
          "<p>அப்படி நல்லநல்ல அவை நல்லநல்ல</p>",
          "<p>அடியார&zwnj;வர்க்கு மிகவே.\"</p>",
          "<p>\"வேள்பட விழிசெய்தென்று விடைமேலிருந்து</p>",
          "<p>மடவாள் தனோடும் உடனாய்</p>",
          "<p>வாள்மதி vanni கொன்றை மலர்சூடி வந்தென்</p>",
          "<p>உளமே புகுந்த வத&zwnj;னால்</p>",
          "<p>ஏழ்கடல் சூழிலங்கை அரையன் ற&zwnj;னோடும்</p>",
          "<p>இடரான வந்து நலியா</p>",
          "<p>ஆழ்கடல் நல்லநல்ல அவை நல்லநல்ல</p>",
          "<p>அடியார&zwnj;வர்க்கு மிகவே.\"</p>",
          "<p>\"பலபல வேடமாகும் பரனாரி பாகன்</p>",
          "<p>பசுவேறும் எங்கள் பரமன்</p>",
          "<p>சலமக ளோடெருக்கு முடிமேல் அணிந்தென்</p>",
          "<p>உளமே புகுந்த அதனால்</p>",
          "<p>மலர்மிசை யோனுமாலும் மறையோடு தேவர்</p>",
          "<p>வருகால மான பலவும்</p>",
          "<p>அலைகடல் மேருநல்ல அவை நல்லநல்ல</p>",
          "<p>அடியார&zwnj;வர்க்கு மிகவே.\"</p>",
          "<p>\"கொத்தல&zwnj;ர் குழலியோடு விசையற்கு நல்கு</p>",
          "<p>குணமாய வேட விகிர்தன்</p>",
          "<p>மத்தமும் மதியும்நாக முடிமேல் அணிந்தென்</p>",
          "<p>உளமே புகுந்த அதனால்</p>",
          "<p>புத்தரொ ட&zwnj;மணைவாதில் அழிவிக்கும் அண்ணல்</p>",
          "<p>திருநீறு செம்மை திடமே</p>",
          "<p>அத்தகு நல்லநல்ல அவை நல்லநல்ல</p>",
          "<p>அடியார&zwnj;வர்க்கு மிகவே.\"</p>",
          "<p>\"தேனமர் பொழில்கள் ஆலை விளைசெந்நெல் துன்னி</p>",
          "<p>வளர் செம்பொன் எங்கும் திகழ</p>",
          "<p>நான்முகன் ஆதியாய பிரமா புரத்து</p>",
          "<p>மறைஞான ஞான முனிவன்</p>",
          "<p>தானுறு கோளும் நாளும் அடியாரை வந்து</p>",
          "<p>நலியாத வண்ணம் உரைசெய்</p>",
          "<p>ஆன சொல்மாலை யோதும் அடியார்கள் வானில்</p>",
          "<p>அரசாள்வர் ஆணை நமதே.\"</p>"
        ]
      }
    }
  ]
}
